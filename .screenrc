# I want all shells within screen to be non-login shells (so that .profile and my ssh-agent kludge don't get executed)
deflogin off
defbce on

# Make sure screen talks to /tmp/ssh-agent-sock-screen for SSH authorization
#unsetenv SSH_AUTH_SOCK
#setenv SSH_AUTH_SOCK /tmp/ssh-agent-sock-screen

# use PROMPT_COMMAND and some nasty ANSI to cram useful info into the titlebar
setenv PROMPT_COMMAND 'echo -ne "\033]0;${USER}@${HOSTNAME}: ${PWD}\007"'

# 10000 lines of scrollback for default windows
defscrollback 10000

# This is on by default, but better safe than sorry. If set to "off" screen
# kills everything when it receives a hangup
autodetach on

# Turn off the annoying startup message
startup_message off

# Make the status line in our title bar a little prettier
hardstatus on
hardstatus string "[%C%A] screen: %h (%t)"

termcapinfo xterm ti@:te@
defutf8 on
