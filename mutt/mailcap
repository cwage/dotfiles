# Render HTML email bodies to text for inline viewing in mutt/neomutt
text/html; w3m -dump -T text/html -I %{charset} -O UTF-8 %s; nametemplate=%s.html; copiousoutput; test=w3m -version >/dev/null 2>&1
text/html; lynx -dump -assume_charset=%{charset} -display_charset=UTF-8 -nolist %s; nametemplate=%s.html; copiousoutput; test=lynx -version >/dev/null 2>&1
